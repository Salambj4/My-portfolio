<!-- =========================
DATABASE (schema.sql)
========================= -->

CREATE DATABASE shop;
USE shop;

CREATE TABLE users (
  id INT AUTO_INCREMENT PRIMARY KEY,
  email VARCHAR(100),
  password VARCHAR(255),
  loyalty_points INT DEFAULT 0
);

CREATE TABLE products (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100),
  price DECIMAL(10,2),
  stock INT
);

CREATE TABLE orders (
  id INT AUTO_INCREMENT PRIMARY KEY,
  user_id INT,
  total DECIMAL(10,2)
);

INSERT INTO products (name, price, stock) VALUES
('Protein Bar', 2.50, 10),
('Energy Drink', 1.80, 15);

