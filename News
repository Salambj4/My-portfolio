<-process order->
$discount = $_POST['discount']; // 0, 10, 20

$total = 0;

// Calculate total
foreach($_SESSION['cart'] as $pid => $qty){

    $res = $conn->query("SELECT * FROM products WHERE id=$pid");
    $product = $res->fetch_assoc();

    $total += $product['price'] * $qty;
}

// APPLY DISCOUNT
if($discount > 0){
    $total = $total - ($total * ($discount / 100));
}



if($discount == 10){
    $conn->query("UPDATE users SET loyaltyPoints = loyaltyPoints - 100 WHERE id=$user_id");
}

if($discount == 20){
    $conn->query("UPDATE users SET loyaltyPoints = loyaltyPoints - 200 WHERE id=$user_id");
}



$earned = floor($total / 10);

$conn->query("UPDATE users 
SET loyaltyPoints = loyaltyPoints + $earned 
WHERE id=$user_id");



