<--cart-->
<?php
session_start();
include("includes/db.php");

// ADD TO CART
if(isset($_POST['product_id'])){

    $pid = $_POST['product_id'];
    $qty = $_POST['quantity'];

    if(isset($_SESSION['cart'][$pid])){
        $_SESSION['cart'][$pid] += $qty;
    } else {
        $_SESSION['cart'][$pid] = $qty;
    }
}

// REMOVE ITEM
if(isset($_GET['remove'])){
    unset($_SESSION['cart'][$_GET['remove']]);
}
?>

<div class="container mt-4">
<h2>Your Cart</h2>

<table class="table">
<tr>
<th>Product</th>
<th>Qty</th>
<th>Price</th>
<th>Total</th>
<th>Action</th>
</tr>

<?php
$total = 0;

if(!empty($_SESSION['cart'])){

foreach($_SESSION['cart'] as $pid => $qty){

    $res = $conn->query("SELECT * FROM products WHERE id=$pid");
    $product = $res->fetch_assoc();

    $sub = $product['price'] * $qty;
    $total += $sub;
?>

<tr>
<td><?php echo $product['name']; ?></td>
<td><?php echo $qty; ?></td>
<td>£<?php echo $product['price']; ?></td>
<td>£<?php echo $sub; ?></td>
<td><a href="?remove=<?php echo $pid; ?>" class="btn btn-danger">Remove</a></td>
</tr>

<?php } } ?>

</table>

<h4>Total: £<?php echo $total; ?></h4>

<a href="checkout.php" class="btn btn-success">Checkout</a>

</div>







<--cart count-->
<?php
$count = 0;
if(isset($_SESSION['cart'])){
    $count = array_sum($_SESSION['cart']);
}
?>

<a href="cart.php" class="nav-link">
Cart🛒 <span class="badge bg-danger"><?php echo $count; ?></span>
</a>






<--Users table-->
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    email VARCHAR(100) UNIQUE,
    password VARCHAR(255),
    role ENUM('customer','admin','supplier') DEFAULT 'customer',
    loyaltyPoints INT DEFAULT 0
);






<--admin supplier-->
