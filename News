<--process_order-->
<?php
session_start();
include("includes/db.php");


// MAKE SURE USER IS LOGGED IN
if(!isset($_SESSION['user'])){
    header("Location: auth/login.php");
    exit();
}

$user_id = $_SESSION['user']['id'];
$email = $_SESSION['user']['email'];

$total = 0;

// CALCULATE TOTAL
foreach($_SESSION['cart'] as $pid => $qty){
    $res = $conn->query("SELECT price FROM products WHERE id=$pid");
    $product = $res->fetch_assoc();
    $total += $product['price'] * $qty;
}

// APPLY DISCOUNT (if exists)
$discount = isset($_SESSION['discount']) ? $_SESSION['discount'] : 0;
$total = $total - ($total * ($discount / 100));

// SAVE ORDER
$stmt = $conn->prepare("INSERT INTO orders (user_id, total, discount) VALUES (?, ?, ?)");
$stmt->bind_param("idi", $user_id, $total, $discount);
$stmt->execute();

$order_id = $stmt->insert_id;

// SAVE ORDER ITEMS
foreach($_SESSION['cart'] as $pid => $qty){

    $res = $conn->query("SELECT price FROM products WHERE id=$pid");
    $product = $res->fetch_assoc();

    $price = $product['price'];

    $stmt = $conn->prepare("INSERT INTO order_items (order_id, product_id, quantity, price) VALUES (?, ?, ?, ?)");
    $stmt->bind_param("iiid", $order_id, $pid, $qty, $price);
    $stmt->execute();
}

// CLEAR CART
unset($_SESSION['discount']);
unset($_SESSION['cart']);

// REDIRECT TO RECEIPT
header("Location: receipt.php?order_id=".$order_id);
exit();






