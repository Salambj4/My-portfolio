<?php
session_start();
include("includes/header.php");
include("includes/db.php");

$order_id = $_GET['order_id'];

// Get order
$order = $conn->query("SELECT * FROM orders WHERE id=$order_id")->fetch_assoc();

// Get items
$items = $conn->query("SELECT * FROM order_items WHERE order_id=$order_id");

$subtotal = 0;
?>

<div class="container mt-4">

<div class="card shadow p-4">

<h2 class="text-center mb-4">Receipt</h2>

<p><strong>Order ID:</strong> <?php echo $order_id; ?></p>
<p><strong>Date:</strong> <?php echo $order['created_at']; ?></p>
<p><strong>Delivery Address:</strong> <?php echo htmlspecialchars($order['address']); ?></p>

<hr>

<h4>Items Purchased</h4>

<table class="table table-bordered">
<tr>
<th>Product</th>
<th>Quantity</th>
<th>Price</th>
<th>Total</th>
</tr>

<?php 
while($item = $items->fetch_assoc()){ 

$product = $conn->query("SELECT name FROM products WHERE id=".$item['product_id'])->fetch_assoc();

$item_total = $item['price'] * $item['quantity'];
$subtotal += $item_total;
?>

<tr>
<td><?php echo $product['name']; ?></td>
<td><?php echo $item['quantity']; ?></td>
<td>£<?php echo $item['price']; ?></td>
<td>£<?php echo $item_total; ?></td>
</tr>

<?php } ?>

</table>

<hr>

<?php
$discount = $order['discount'];
$discount_amount = $subtotal * ($discount / 100);
$final_total = $subtotal - $discount_amount;
?>

<p><strong>Subtotal:</strong> £<?php echo number_format($subtotal,2); ?></p>

<p><strong>Discount:</strong> <?php echo $discount; ?>% (-£<?php echo number_format($discount_amount,2); ?>)</p>

<h4><strong>Final Total: £<?php echo number_format($final_total,2); ?></strong></h4>

<hr>

<p class="text-center">Thank you for shopping with us 🌱</p>

</div>

</div>

