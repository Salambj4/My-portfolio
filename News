<--process-->
<?php
session_start();
include("includes/db.php");

$user_id = $_SESSION['user']['id'];
$address = $_POST['address'];

$total = 0;

// CALCULATE TOTAL
foreach($_SESSION['cart'] as $pid => $qty){
    $res = $conn->query("SELECT * FROM products WHERE id=$pid");
    $product = $res->fetch_assoc();

    $total += $product['price'] * $qty;
}

// CREATE ORDER
$conn->query("INSERT INTO orders (user_id, total, address)
VALUES ($user_id, $total, '$address')");

$order_id = $conn->insert_id;

// LOOP PRODUCTS
foreach($_SESSION['cart'] as $pid => $qty){

    $res = $conn->query("SELECT * FROM products WHERE id=$pid");
    $product = $res->fetch_assoc();

    $price = $product['price'];

    // SAVE ORDER ITEM
    $conn->query("INSERT INTO order_items (order_id, product_id, quantity, price)
    VALUES ($order_id, $pid, $qty, $price)");

    // UPDATE STOCK
    $conn->query("UPDATE products SET stock = stock - $qty WHERE id=$pid");

    // 🔥 SUPPLIER NOTIFICATION
    if($product['stock'] - $qty < 5){
        $conn->query("INSERT INTO supplier_notifications 
        (supplier_id, product_id, message)
        VALUES ({$product['supplier_id']}, $pid, 'Restock needed')");
    }
}

// CLEAR CART
unset($_SESSION['cart']);
$_SESSION['cart_count'] = 0;

// GO TO RECEIPT
header("Location: receipt.php?order_id=$order_id");


