<--save_enquiry.php-->
<?php
include("includes/db.php");


if($_SERVER["REQUEST_METHOD"] == "POST"){

$name = $_POST['name'];
$email = $_POST['email'];
$message = $_POST['message'];

// INSERT INTO DATABASE
$stmt = $conn->prepare("INSERT INTO enquiries (name, email, message) VALUES (?, ?, ?)");
$stmt->bind_param("sss", $name, $email, $message);

if($stmt->execute()){
    echo "<script>alert('Enquiry sent successfully!'); window.location='contact.php';</script>";
} else {
    echo "Error saving enquiry.";
}

}

if(empty($name) || empty($email) || empty($message)){
    die("All fields are required");
}



<--accessibility-->
<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Accessibility</a>

<ul class="dropdown-menu">
<li><button class="dropdown-item" onclick="toggleContrast()">High Contrast</button></li>
<li><button class="dropdown-item" onclick="increaseText()">Increase Text</button></li>
<li><button class="dropdown-item" onclick="decreaseText()">Decrease Text</button></li>
<li><button class="dropdown-item" onclick="readPage()">Screen Reader</button></li>
</ul>
</li>





<--script-->
function toggleContrast(){
    document.body.classList.toggle("high-contrast");
}



let currentSize = 16;

function increaseText(){
    currentSize += 2;
    document.body.style.fontSize = currentSize + "px";
}

function decreaseText(){
    currentSize -= 2;
    document.body.style.fontSize = currentSize + "px";
}





document.addEventListener("keydown", function(e){

    // Press "H" for contrast
    if(e.key === "h"){
        toggleContrast();
    }

    // Press "+" to zoom in
    if(e.key === "+"){
        increaseText();
    }

    // Press "-" to zoom out
    if(e.key === "-"){
        decreaseText();
    }

});



<--style-->
.high-contrast {
    background-color: black !important;
    color: white !important;
}

.high-contrast a {
    color: yellow !important;
}

.high-contrast .card {
    background-color: black;
    color: white;
}







